{{- /* PWA manifest. Prefers a raster `images/logo.png` (resized to 192/512
       for Lighthouse compliance); falls back to the bundled SVG if no
       PNG is available. Sites that want full PWA install support should
       ship `assets/images/logo.png` at ≥512×512. */ -}}
{{- $icon := resources.Get "images/logo.png" -}}
{{- $iconSVG := resources.Get "images/logo.svg" -}}
{{- $shortTitle := .Site.Params.shortTitle | default .Site.Title -}}
{{- $themeColor := .Site.Params.theme.primaryColor | default "#0f4c81" -}}
{{- $bgColor := .Site.Params.theme.backgroundColor | default "#ffffff" -}}
{{- $icons := slice -}}
{{- with $icon -}}
    {{- $i192 := .Resize "192x192" -}}
    {{- $i512 := .Resize "512x512" -}}
    {{- $icons = $icons | append (dict "src" $i192.RelPermalink "sizes" "192x192" "type" "image/png") -}}
    {{- $icons = $icons | append (dict "src" $i512.RelPermalink "sizes" "512x512" "type" "image/png") -}}
{{- else -}}
    {{- with $iconSVG -}}
        {{- $icons = $icons | append (dict "src" .RelPermalink "sizes" "any" "type" "image/svg+xml") -}}
    {{- end -}}
{{- end -}}
{{- $manifest := dict
    "name"             .Site.Title
    "short_name"       $shortTitle
    "lang"             .Language.Lang
    "dir"              (.Language.Direction | default "ltr")
    "description"      .Site.Params.description
    "start_url"        ("/" | relLangURL)
    "scope"            ("/" | relLangURL)
    "background_color" $bgColor
    "theme_color"      $themeColor
    "display"          "standalone"
    "icons"            $icons
-}}
{{ $manifest | jsonify (dict "indent" "    ") }}
